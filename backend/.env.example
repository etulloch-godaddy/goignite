# GoCaaS AI key — set this to enable AI-generated content (social media plans, SEO, content ideas)
# Without this key, all AI features fall back to mock/demo data automatically
# Get your key from the GoCaaS team (must start with sk-)
API_KEY=

# GoDaddy domain availability API
GODADDY_API_KEY=
GODADDY_API_SECRET=
GODADDY_OTE=true

# Social platform OAuth (optional — leave blank to use mock social stats)
MOCK_SOCIAL_APIS=true
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/social/callback/instagram
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/api/social/callback/tiktok
